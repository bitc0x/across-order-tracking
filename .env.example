# 1inch Fusion dev portal API key
# https://portal.1inch.dev/
DEV_PORTAL_API_TOKEN=

# Vercel KV — provisioned via Vercel dashboard (Storage → Create → KV)
# All four are auto-set when KV is linked to the project.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Random 32+ char string. Vercel Cron sends this in Authorization: Bearer <secret>
CRON_SECRET=
