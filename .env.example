# 1inch Fusion dev portal API key
# https://portal.1inch.dev/
DEV_PORTAL_API_TOKEN=

# Vercel's Upstash for Redis Marketplace integration injects these.
# The prefix is configurable when you install the integration; the
# store accepts either naming convention so the same code works
# regardless of which one Vercel set:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Equivalent (used when KV is chosen as the prefix at install time, which
# is the default for projects migrated from Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Random ≥32 char string. Vercel Cron sends this in Authorization: Bearer <secret>
CRON_SECRET=
