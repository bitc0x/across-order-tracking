# 1inch Fusion dev portal API key
# https://portal.1inch.dev/
DEV_PORTAL_API_TOKEN=

# Redis (Upstash via Vercel Marketplace).
# Vercel auto-injects these when the Upstash for Redis integration is connected.
# Both naming conventions are supported by the store; whichever the integration
# sets at provisioning time will work.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy aliases (for projects migrated from Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Random ≥32 char string. Vercel Cron sends this in Authorization: Bearer <secret>
CRON_SECRET=
